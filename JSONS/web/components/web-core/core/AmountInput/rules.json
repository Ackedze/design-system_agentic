{
  "schemaVersion": 1,
  "documentType": "component-rules",
  "componentKey": "web-core.amount-input",
  "status": "draft",
  "rules": [
    {
      "ruleId": "component:web-core.amount-input.variant-state-is-component-property",
      "severity": "info",
      "source": "component-contract",
      "appliesTo": "variant.*",
      "checkType": "deterministic",
      "ruleText": "Изменения Size, FilledState, ActiveState, DisabledState, ErrorState и OuterLabel являются component property changes и должны показываться как самостоятельные customizations."
    },
    {
      "ruleId": "component:web-core.amount-input.manual-field-visual-is-layer-property",
      "severity": "warning",
      "source": "component-contract",
      "appliesTo": "Field.fills|Field.strokes|Field.radius|Field.layout",
      "checkType": "deterministic",
      "ruleText": "Ручные visual/layout изменения на Field являются layer customizations и должны показываться отдельно от изменений component property."
    },
    {
      "ruleId": "component:web-core.amount-input.manual-text-style-is-layer-property",
      "severity": "warning",
      "source": "component-contract",
      "appliesTo": "Label.styles.text|Placeholder.styles.text|HintMessage.styles.text",
      "checkType": "deterministic",
      "ruleText": "Ручные изменения text style на Label, Placeholder или HintMessage являются layer customizations и должны сбрасываться независимо."
    },
    {
      "ruleId": "component:web-core.amount-input.amount-format-pattern-rules",
      "severity": "error",
      "source": "pattern-link",
      "patternRuleIds": [
        "rule:components.amount.math-space",
        "rule:components.amount.math-minus",
        "rule:components.amount.no-opacity"
      ],
      "appliesTo": "Amount.characters|Amount.opacity",
      "checkType": "deterministic+llm",
      "ruleText": "Текст/content суммы должен соответствовать правилам форматирования сумм: математические пробелы, математический минус и отсутствие opacity для частей суммы там, где это запрещено."
    },
    {
      "ruleId": "component:web-core.amount-input.label-placeholder-hint-pattern-rules",
      "severity": "warning",
      "source": "pattern-link",
      "patternRuleIds": [
        "rule:controls.input-fields.noun-label",
        "rule:controls.input-fields.no-label-colon",
        "rule:controls.input-fields.no-placeholder-duplication",
        "rule:controls.input-fields.short-useful-hint"
      ],
      "appliesTo": "Label.characters|Placeholder.characters|HintMessage.characters",
      "checkType": "llm+deterministic",
      "ruleText": "Тексты label, placeholder и hint должны соответствовать текстовым правилам input-field."
    }
  ]
}
