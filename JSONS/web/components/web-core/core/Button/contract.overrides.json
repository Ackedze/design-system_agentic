{
  "schemaVersion": 1,
  "documentType": "component-contract-overrides",
  "componentKey": "web-core.button",
  "status": "draft",
  "appliesTo": {
    "generatedContract": "contract.generated.json",
    "rawCatalog": "Web _ Core -- Button.json"
  },
  "publicApi": {
    "variantProperties": {
      "View": {
        "kind": "component-property",
        "description": "Визуальный style/state кнопки.",
        "values": [
          "Primary",
          "Secondary",
          "Transparent",
          "Text",
          "Accent",
          "Outlined"
        ]
      },
      "Size": {
        "kind": "component-property",
        "description": "Состояние высоты/size кнопки.",
        "values": [
          "32",
          "40",
          "48",
          "56",
          "64",
          "72"
        ]
      },
      "Shape": {
        "kind": "component-property",
        "description": "Состояние формы углов.",
        "values": [
          "Rectangular",
          "Rounded"
        ]
      },
      "SingleIcon": {
        "kind": "component-property",
        "description": "Переключает кнопку в icon-only/single-icon visual state.",
        "values": [
          "False",
          "True"
        ]
      },
      "DisabledState": {
        "kind": "component-property",
        "description": "Состояние компонента disabled/enabled.",
        "values": [
          "False",
          "True"
        ]
      }
    }
  },
  "anatomySemantics": {
    "root": {
      "path": "<variant root>",
      "scope": "component-root",
      "designerEditable": false,
      "notes": "Root layout, radius и fill управляются component variant properties и design tokens."
    },
    "label": {
      "path": "Text / Label",
      "scope": "content-layer",
      "designerEditable": "content-only",
      "notes": "Text content можно менять. Text style и fill являются layer parameters и обычно должны оставаться под управлением variant."
    },
    "hint": {
      "path": "Text / Hint",
      "scope": "content-layer",
      "designerEditable": "content-only",
      "notes": "Hint присутствует в структуре компонента, но desktop-использование ограничено pattern rules."
    },
    "leftAddon": {
      "path": "LeftAddon / LeftAddon",
      "scope": "slot-instance",
      "designerEditable": "variant-property-only",
      "notes": "Вложенный addon instance. Его variant properties являются slot configuration, а не свободной layer styling."
    },
    "rightAddon": {
      "path": "RightAddon / RightAddon",
      "scope": "slot-instance",
      "designerEditable": "variant-property-only",
      "notes": "Вложенный addon instance. Его variant properties являются slot configuration, а не свободной layer styling."
    },
    "paintMe": {
      "path": "*/PaintMe",
      "scope": "internal-layer",
      "designerEditable": false,
      "notes": "Внутренний paint target. Ручные изменения fill нужно трактовать как layer customization."
    }
  },
  "resetModel": {
    "componentProperties": [
      "variant.View",
      "variant.Size",
      "variant.Shape",
      "variant.SingleIcon",
      "variant.DisabledState"
    ],
    "slotProperties": [
      "LeftAddon.variant.Type",
      "RightAddon.variant.Type"
    ],
    "layerProperties": [
      "fills",
      "strokes",
      "strokeWeight",
      "cornerRadius",
      "opacity",
      "layout.padding",
      "layout.itemSpacing",
      "styles.text",
      "typography"
    ],
    "dependencyPolicy": "При reset component property layer differences, вызванные только этой property, могут исчезнуть автоматически. Ручные layer overrides должны оставаться независимо сбрасываемыми, пока reset родительской property не уберёт их target state."
  }
}
