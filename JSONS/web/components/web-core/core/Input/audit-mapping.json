{
  "schemaVersion": 1,
  "documentType": "component-audit-mapping",
  "componentKey": "web-core.input",
  "status": "draft",
  "applicability": {
    "channels": [
      "universal"
    ],
    "platforms": [
      "desktop",
      "mobile-web"
    ],
    "source": "path-policy",
    "updatedAt": "2026-07-04"
  },
  "classification": [
    {
      "match": {
        "propertyPrefix": "variant."
      },
      "scope": "component-property",
      "groupTitle": "Параметры компонента",
      "priority": 10,
      "resetAction": "reset-component-properties"
    },
    {
      "match": {
        "property": "fill"
      },
      "scope": "layer-property",
      "groupTitle": "Параметры слоя",
      "priority": 30,
      "resetAction": "reset-layer-properties"
    },
    {
      "match": {
        "property": "stroke"
      },
      "scope": "layer-property",
      "groupTitle": "Параметры слоя",
      "priority": 31,
      "resetAction": "reset-layer-properties"
    },
    {
      "match": {
        "property": "strokeWeight"
      },
      "scope": "layer-property",
      "groupTitle": "Параметры слоя",
      "priority": 32,
      "resetAction": "reset-layer-properties"
    },
    {
      "match": {
        "property": "styles.text"
      },
      "scope": "layer-property",
      "groupTitle": "Параметры слоя",
      "displayName": "Стиль текст",
      "priority": 40,
      "resetAction": "reset-layer-properties"
    },
    {
      "match": {
        "propertyPrefix": "layout."
      },
      "scope": "layer-property",
      "groupTitle": "Параметры слоя",
      "priority": 50,
      "resetAction": "reset-layer-properties"
    },
    {
      "match": {
        "nodePathIncludes": "LeftAddons / LeftAddon",
        "propertyPrefix": "variant."
      },
      "scope": "slot-property",
      "groupTitle": "Параметры слота",
      "priority": 15,
      "resetAction": "reset-component-properties"
    },
    {
      "match": {
        "nodePathIncludes": "RightAddons / RightAddon",
        "propertyPrefix": "variant."
      },
      "scope": "slot-property",
      "groupTitle": "Параметры слота",
      "priority": 15,
      "resetAction": "reset-component-properties"
    },
    {
      "match": {
        "nodePathIncludes": "Placeholder",
        "propertyPrefix": "variant."
      },
      "scope": "slot-property",
      "groupTitle": "Параметры слота",
      "priority": 16,
      "resetAction": "reset-component-properties"
    },
    {
      "match": {
        "property": "characters"
      },
      "scope": "content-property",
      "groupTitle": "Текстовое содержимое",
      "priority": 60,
      "resetAction": "manual-content-review"
    }
  ],
  "groupingOrder": [
    "component-property",
    "slot-property",
    "layer-property",
    "content-property"
  ],
  "evidencePolicy": {
    "showVariantBeforeDerivedVisuals": true,
    "useChangedNodeAsAffectedTarget": true,
    "keepLayerOverrideSeparateFromVariantChange": true,
    "doNotTreatContentTextAsVisualCustomizationWithoutTextRule": true
  },
  "baselinePolicy": {
    "whenVariantChanged": "Use the actual variant state as baseline for layer comparisons. Example: if ErrorState changed False -> True and Field fill was also manually changed, expected fill should be ErrorState=True baseline.",
    "whenResettingLayer": "Reset layer property to the baseline of the current component property state.",
    "whenResettingComponentProperty": "Reset component property to reference value; derived layer differences may disappear if caused only by state change."
  }
}
