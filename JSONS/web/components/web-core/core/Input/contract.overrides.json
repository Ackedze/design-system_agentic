{
  "schemaVersion": 1,
  "documentType": "component-contract-overrides",
  "componentKey": "web-core.input",
  "status": "draft",
  "appliesTo": {
    "generatedContract": "contract.generated.json",
    "rawCatalog": "Web _ Core -- Input.json"
  },
  "publicApi": {
    "variantProperties": {
      "Size": {
        "kind": "component-property",
        "description": "Height/size state компонента Input.",
        "values": [
          "40",
          "48",
          "56",
          "64",
          "72"
        ]
      },
      "FilledState": {
        "kind": "component-property",
        "description": "Есть ли у input filled/value state.",
        "values": [
          "False",
          "True"
        ]
      },
      "ActiveState": {
        "kind": "component-property",
        "description": "Focus/active visual state компонента.",
        "values": [
          "False",
          "True"
        ]
      },
      "DisabledState": {
        "kind": "component-property",
        "description": "Состояние компонента disabled/enabled.",
        "values": [
          "False",
          "True"
        ]
      },
      "ErrorState": {
        "kind": "component-property",
        "description": "Validation/error visual state компонента.",
        "values": [
          "False",
          "True"
        ]
      },
      "OuterLabel": {
        "kind": "component-property",
        "description": "Размещён ли label снаружи/над field вместо inside/floating.",
        "values": [
          "False",
          "True"
        ]
      }
    }
  },
  "anatomySemantics": {
    "root": {
      "path": "<variant root>",
      "scope": "component-root",
      "designerEditable": false,
      "notes": "Root visibility/layout управляется component variant properties."
    },
    "label": {
      "path": "Label / Label",
      "scope": "content-layer",
      "designerEditable": "content-only",
      "notes": "Label text можно менять. Text style, fill и placement управляются состоянием компонента и pattern rules."
    },
    "field": {
      "path": "Field",
      "scope": "visual-container",
      "designerEditable": false,
      "notes": "Field fill, radius, stroke и layout управляются size/state variants."
    },
    "placeholder": {
      "path": "Field / Content / Placeholder / Content / Placeholder",
      "scope": "content-layer",
      "designerEditable": "content-only",
      "notes": "Placeholder text можно менять. Text style и fill являются layer properties и обычно должны оставаться под управлением variant."
    },
    "hint": {
      "path": "Hint / HintMessage",
      "scope": "content-layer",
      "designerEditable": "content-only",
      "notes": "Hint или error text можно менять. ErrorState управляет тем, интерпретируется ли этот текст как validation/error state."
    },
    "addons": {
      "path": "Field / LeftAddons/*, Field / RightAddons/*",
      "scope": "slot-instance",
      "designerEditable": "variant-property-only",
      "notes": "Addon instances являются slot configuration. Ручные fills/strokes на addon placeholders являются layer customizations."
    }
  },
  "resetModel": {
    "componentProperties": [
      "variant.Size",
      "variant.FilledState",
      "variant.ActiveState",
      "variant.DisabledState",
      "variant.ErrorState",
      "variant.OuterLabel"
    ],
    "slotProperties": [
      "LeftAddon1.variant.Type",
      "LeftAddon2.variant.Type",
      "RightAddon1.variant.Type",
      "RightAddon2.variant.Type",
      "Placeholder.variant.Accent"
    ],
    "layerProperties": [
      "fills",
      "strokes",
      "strokeWeight",
      "cornerRadius",
      "opacity",
      "layout.padding",
      "layout.itemSpacing",
      "styles.text",
      "typography"
    ],
    "contentProperties": [
      "Label.characters",
      "Placeholder.characters",
      "HintMessage.characters"
    ],
    "dependencyPolicy": "При reset состояния компонента layer differences, вызванные только этим состоянием, могут исчезнуть автоматически. Ручные layer overrides должны оставаться независимо сбрасываемыми, пока reset родительского состояния не уберёт их target state."
  }
}
