{
  "schemaVersion": 1,
  "documentType": "component-contract-examples",
  "componentKey": "web-core-navigation.tabs",
  "status": "draft",
  "applicability": {
    "channels": [
      "universal"
    ],
    "platforms": [
      "desktop",
      "mobile-web"
    ],
    "source": "path-policy",
    "updatedAt": "2026-07-04"
  },
  "examples": [
    {
      "exampleId": "tabs.tab-primary-standalone-spacing-change",
      "title": "Manual standalone TabPrimary spacing change should be reported",
      "inputChange": {
        "rootComponent": "🔩 TabPrimary",
        "node": "ActiveState=True, DisabledState=False",
        "property": "layout.itemSpacing",
        "referenceValue": 12,
        "actualValue": 16
      },
      "expectedAudit": {
        "category": "customizations",
        "showAs": "Отступ между элементами: 12 → 16"
      }
    },
    {
      "exampleId": "tabs.tabs-view-owned-primary-tab-spacing",
      "title": "TabsView-owned TabPrimary spacing should not be reported as core Tabs customization",
      "inputChange": {
        "hostComponent": "[D] TabsView",
        "nestedComponent": "TabPrimary",
        "property": "layout.itemSpacing",
        "standaloneCoreTabsValue": 12,
        "tabsViewEffectiveValue": 16,
        "actualValue": 16
      },
      "expectedAudit": {
        "category": "none",
        "suppressReason": "actual equals host TabsView effective baseline"
      }
    },
    {
      "exampleId": "tabs.tabs-view-owned-primary-label-style",
      "title": "TabsView-owned TabPrimary label typography should not be reported as core Tabs customization",
      "inputChange": {
        "hostComponent": "[D] TabsView",
        "nestedComponent": "TabPrimary / Label",
        "property": "styles.text",
        "standaloneCoreTabsValue": "Paragraph/18–24 Primary Large",
        "tabsViewEffectiveValue": "Action/18–24 Primary Large",
        "actualValue": "Action/18–24 Primary Large"
      },
      "expectedAudit": {
        "category": "none",
        "suppressReason": "actual equals host TabsView effective baseline"
      }
    },
    {
      "exampleId": "tabs.tabs-view-manual-primary-label-style-change",
      "title": "Manual change beyond TabsView baseline should be reported from host baseline",
      "inputChange": {
        "hostComponent": "[D] TabsView",
        "nestedComponent": "TabPrimary / Label",
        "property": "styles.text",
        "standaloneCoreTabsValue": "Paragraph/18–24 Primary Large",
        "tabsViewEffectiveValue": "Action/18–24 Primary Large",
        "actualValue": "Action/11–16 Secondary Small"
      },
      "expectedAudit": {
        "category": "customizations",
        "showAs": "Стиль текст: Action/18–24 Primary Large → Action/11–16 Secondary Small"
      }
    }
  ]
}
