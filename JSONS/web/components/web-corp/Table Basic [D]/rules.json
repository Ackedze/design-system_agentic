          "Chevron",
          "Control",
          "Graphics",
          "GraphicsSkeleton",
          "HeadControl",
          "LeftAddon",
          "RightAddon",
          "Sorting",
          "Text"
        ]
      },
      "ruleText": "Изменения variant/property в компонентах семейства таблиц являются component-property customizations. Показывай их отдельно от производных визуальных изменений layer."
    },
    {
      "ruleId": "component:web-corp.table-basic-d.layer-properties-use-effective-baseline",
      "severity": "warning",
      "source": "composition-contract",
      "appliesTo": "layout.*|styles.text|fill|stroke|radius|opacity",
      "checkType": "deterministic",
      "matchKind": "exact_component_rule",
      "target": {
        "component": "web-corp.table-basic-d",
        "layers": [
          "[D] BodyActionCell",
          "[D] BodyActionCell :: Basic",
          "[D] BodyCell",
          "[D] BodyCell :: Basic",
          "[D] BodyControlCell",
          "[D] BodyControlCell :: Basic",
          "[D] BodyRow",
          "[D] BodyRow :: Basic",
          "[D] BodyRow :: Core",
          "[D] GroupDivider",
          "[D] GroupDivider :: Basic",
          "[D] HeadActionCell",
          "[D] HeadCell",
          "[D] HeadControlCell",
          "[D] HeadRow",
          "[D] HeadRow :: Core",
          "[D] ListHeaderRow",
          "[D] ListHeaderRow :: Core",
          "🔄 [D] BodyActionCell",
          "🔄 [D] BodyCell",
          "🔄 [D] BodyControlCell",
          "🔄 [D] BodyRow :: Core",
          "🔄 [D] HeadActionCell",
          "🔄 [D] HeadCell",
          "🔄 [D] HeadControlCell",
          "🔄 [D] HeadRow :: Core",
          "🔄 [D] ListHeaderRow :: Core",
