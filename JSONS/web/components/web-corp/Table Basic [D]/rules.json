      "severity": "info",
      "source": "component-contract",
      "appliesTo": "variant.*",
      "checkType": "deterministic",
      "matchKind": "exact_component_rule",
      "target": {
        "component": "web-corp.table-basic-d",
        "layers": [
          "[D] BodyActionCell",
          "[D] BodyActionCell :: Basic",
          "[D] BodyCell",
          "[D] BodyCell :: Basic",
          "[D] BodyControlCell",
          "[D] BodyControlCell :: Basic",
          "[D] BodyRow",
          "[D] BodyRow :: Basic",
          "[D] BodyRow :: Core",
          "[D] GroupDivider",
          "[D] GroupDivider :: Basic",
          "[D] HeadActionCell",
          "[D] HeadCell",
          "[D] HeadControlCell",
          "[D] HeadRow",
          "[D] HeadRow :: Core",
          "[D] ListHeaderRow",
          "[D] ListHeaderRow :: Core",
          "🔄 [D] BodyActionCell",
          "🔄 [D] BodyCell",
          "🔄 [D] BodyControlCell",
          "🔄 [D] BodyRow :: Core",
          "🔄 [D] HeadActionCell",
          "🔄 [D] HeadCell",
          "🔄 [D] HeadControlCell",
          "🔄 [D] HeadRow :: Core",
          "🔄 [D] ListHeaderRow :: Core",
