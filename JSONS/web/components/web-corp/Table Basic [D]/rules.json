        ]
      },
      "ruleText": "Изменения layer/style внутри компонентов семейства таблиц нужно сравнивать с effective baseline текущего table variant и nested owner context."
    },
    {
      "ruleId": "component:web-corp.table-basic-d.scheduled-parts-are-informational",
      "severity": "info",
      "source": "component-contract",
      "appliesTo": "component.status",
      "checkType": "manual",
      "ruleText": "Scheduled-части таблиц являются lifecycle context для агента. Не считай scheduled status дизайн-нарушением, если не найден отдельный pattern или exact design rule."
    },
    {
      "ruleId": "component:web-corp.table-basic-d.background-plate-wrapper-in-content",
      "severity": "error",
      "source": "composition-contract",
      "appliesTo": "screen.composition",
      "checkType": "llm",
      "matchKind": "composition_rule",
      "conditions": {
        "component": "Table Basic [D]",
        "placement": "CorporateContent body"
      },
      "requiredComposition": {
        "wrapperComponent": "BackgroundPlate",
        "level": "Level 1",
        "background": "matching page background",
        "padding": {
          "top": 0,
          "right": 16,
          "bottom": 16,
          "left": 16
        }
      },
      "ruleText": "При размещении Table Basic [D] в теле CorporateContent под таблицу нужно подкладывать BackgroundPlate первого уровня с соответствующим фоном. Отступы от краёв BackgroundPlate до таблицы: слева 16 px, справа 16 px, снизу 16 px, сверху 0 px."
    }
  ]
