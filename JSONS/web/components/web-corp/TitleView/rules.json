{
  "schemaVersion": 1,
  "documentType": "component-rules",
  "componentKey": "web-corp.title-view",
  "status": "draft",
  "rules": [
    {
      "id": "component:web-corp.title-view.component-properties",
      "title": "Component properties TitleView нужно проверять как параметры компонента",
      "matchKind": "exact_rule",
      "severity": "medium",
      "selector": {
        "componentNames": [
          "[D] RightAddon",
          "[D] RightAddonXL",
          "[D] TitleAddon",
          "[D] TitleAddonXL",
          "[D] TitleStatus",
          "[D] TitleView",
          "[M] RightAddon",
          "[M] RightAddonXL",
          "[M] TitleAddon",
          "[M] TitleAddonXL",
          "[M] TitleStatus",
          "[M] TitleView"
        ],
        "propertyPrefix": "variant."
      },
      "rule": "Изменения variant/property на instance компонента являются component-property customizations. Не превращай их в несвязанные paint или layout findings."
    },
    {
      "id": "component:web-corp.title-view.layer-properties",
      "title": "Layer properties TitleView должны использовать effective baseline",
      "matchKind": "exact_rule",
      "severity": "medium",
      "selector": {
        "componentNames": [
          "[D] RightAddon",
          "[D] RightAddonXL",
          "[D] TitleAddon",
          "[D] TitleAddonXL",
          "[D] TitleStatus",
          "[D] TitleView",
          "[M] RightAddon",
          "[M] RightAddonXL",
          "[M] TitleAddon",
          "[M] TitleAddonXL",
          "[M] TitleStatus",
          "[M] TitleView"
        ],
        "properties": [
          "layout.itemSpacing",
          "layout.padding.*",
          "styles.text",
          "styles.fill",
          "styles.stroke",
          "fill",
          "stroke",
          "radius",
          "opacity"
        ]
      },
      "rule": "Изменения layer/style нужно сравнивать с effective baseline текущего component variant и nested owner context."
    }
  ]
}
